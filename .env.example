# ============================================================
# ===== NEW: EMAIL CONFIGURATION FOR SENTIMENT REPORTS =====
# ============================================================

# SMTP Server Configuration
# For Gmail: smtp.gmail.com
# For Outlook: smtp.office365.com
# For SendGrid: smtp.sendgrid.net
SMTP_HOST=smtp.gmail.com

# SMTP Port
# Standard: 587 (TLS) or 465 (SSL)
SMTP_PORT=587

# SMTP Username (usually your email address)
# For Gmail: your-email@gmail.com
# For SendGrid: apikey
SMTP_USER=your-email@gmail.com

# SMTP Password
# For Gmail: Use 16-character App Password (NOT your regular Gmail password)
# Instructions: https://myaccount.google.com/apppasswords
# For SendGrid: Your SG API key
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# Email "From" Address
# Usually same as SMTP_USER
EMAIL_FROM=your-email@gmail.com

# Email Recipients for Sentiment Analysis Reports
# Comma-separated list (no spaces before emails)
# Example: admin@company.com,boss@company.com,support@company.com
EMAIL_RECIPIENTS=admin@example.com,manager@example.com

# Optional: Separate sheet for comments (if not set, uses main SHEET_ID)
# Leave empty to use the main sheet
# COMMENTS_SHEET_ID=1xxxxxxxxxxxxx

# ============================================================
# CONFIGURATION NOTES
# ============================================================
# 
# 1. Do NOT add quotes around values (except in comments)
# 2. Do NOT add spaces around the = sign
# 3. SMTP_PASSWORD: For Gmail, you MUST use App Password, not your Gmail password
#    Get it from: https://myaccount.google.com/apppasswords
# 4. EMAIL_RECIPIENTS: Use comma WITHOUT spaces between emails
#    WRONG: admin@example.com , manager@example.com
#    RIGHT: admin@example.com,manager@example.com
# 5. Keep this file in .gitignore (secrets!)
# 6. .env is loaded automatically by dotenv package
# 
# ============================================================
# FEATURES ENABLED
# ============================================================
# 
# With this configuration, you get:
# - Automatic comment collection from Facebook posts
# - Real-time sentiment analysis using Gemini AI
# - Comments stored in "Comments" tab in Google Sheets
# - Daily email reports at 9 AM UTC
# - Milestone reports (every 10, 50, 100 comments)
# - API endpoints for manual reports and exports
# 
# API Endpoints:
# GET  http://localhost:3000/comment-stats
# POST http://localhost:3000/send-sentiment-report
# GET  http://localhost:3000/trigger-daily-report
# GET  http://localhost:3000/comments-export
# 
# ============================================================
